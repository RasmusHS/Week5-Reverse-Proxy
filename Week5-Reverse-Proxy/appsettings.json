{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day"
        }
      }
    ]
  },

  "AdminAuth": {
    "Username": "admin",
    "Password": "supersecret"
  },

  "ReverseProxy": {
    "Routes": {
      "route1": {
        "ClusterId": "cluster1",
        "Match": {
          "Path": "/api/{**remainder}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/api"
          },
          {
            "RequestHeader": "X-Forwarded-By",
            "Set": "YarpProxy"
          },
          {
            "ResponseHeaderRemove": "Server"
          }
        ]
      },
      "route2": {
        "ClusterId": "cluster2",
        "Match": {
          "Path": "/web/{**remainder}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/web"
          }
        ]
      },
      "admin": {
        "ClusterId": "cluster1",
        "Match": {
          "Path": "/admin/{**remainder}"
        },
        "AuthorizationPolicy": "AdminPolicy",
        "Transforms": [
          {
            "PathRemovePrefix": "/admin"
          },
          {
            "RequestHeader": "X-Forwarded-By",
            "Set": "YarpProxyAdmin"
          },
          {
            "ResponseHeaderRemove": "Server"
          }
        ]
      }
    },
    "Clusters": {
      "cluster1": {
        "Destinations": {
          "destination1": {
            "Address": "https://httpbin.org/"
          }
        }
      },
      "cluster2": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5081/"
          }
        }
      }
    }
  }
}
